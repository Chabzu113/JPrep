{
  "name": "jprep",
  "version": "2.3.0",
  "description": "JPrep — Multi-Subject AP Practice Platform",
  "main": "main.js",
  "author": "Abhijay Ramaka",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "npm run copy-files && electron-builder --mac",
    "build:win": "npm run copy-files && electron-builder --win",
    "copy-files": "cp -r ../index.html ../question-bank.html ../practice-test.html ../review.html ../results.html ../subject-select.html ../planner.html ../css ../js ../problems . && node scripts/sync-version.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.abhijay.jprep",
    "productName": "JPrep",
    "icon": "icon.png",
    "mac": {
      "category": "public.app-category.education",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "artifactName": "${productName}-Mac.${ext}",
      "icon": "icon.png"
    },
    "dmg": {
      "title": "JPrep",
      "icon": "icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png",
      "artifactName": "JPrep-Win.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "question-bank.html",
      "practice-test.html",
      "review.html",
      "results.html",
      "subject-select.html",
      "planner.html",
      "css/**/*",
      "js/**/*",
      "problems/**/*"
    ],
    "extraResources": [],
    "directories": {
      "output": "../dist"
    }
  }
}
